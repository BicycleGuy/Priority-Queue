# Switchboard OAuth Relay — Environment Variables
#
# Copy to .env and fill in values.
# Generate RELAY_ENCRYPTION_KEY with: openssl rand -hex 32

RELAY_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
RELAY_GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
RELAY_ENCRYPTION_KEY=your-64-char-hex-key
RELAY_BASE_URL=https://relay.yourdomain.com
